import {
  ChangeDetectionStrategy,
  Component,
  computed,
  inject,
  input,
  OnDestroy,
  PLATFORM_ID,
  signal,
} from '@angular/core';
import { isPlatformBrowser } from '@angular/common';
import { Router, RouterLink, RouterLinkActive, NavigationEnd, Event } from '@angular/router';
import { NgOptimizedImage } from '@angular/common';
import { LucideAngularModule } from 'lucide-angular';
import {
  LayoutDashboard,
  Package,
  FolderTree,
  ShoppingCart,
  Users,
  Settings,
  FileText,
  PanelLeftClose,
  PanelLeftOpen,
  Ellipsis,
  ChevronDown,
} from 'lucide-angular';
import { LucideIconData } from 'lucide-angular';
import { SIDEBAR_STORAGE_KEY } from '@/core/constants/local-storage-key';
import { LocalStorageService } from '@/core/services/local-storage/local-storage.service';
import type { Subscription } from 'rxjs';

/**
 * Simpler sidebar with accordion behavior.
 *
 * - Uses a CSS-based max-height transition (no JS height measurement).
 * - Only one group can be open at a time (accordion).
 * - Syncs the open group with the current route.
 * - Persists collapsed state and last-open group (optional).
 * - Avoids DOM measurements so it is simpler and resilient.
 */

export interface SidebarItem {
  readonly label: string;
  readonly href: string;
  readonly icon?: LucideIconData;
}

export interface SidebarGroup {
  readonly label: string;
  readonly icon?: LucideIconData;
  readonly items: SidebarItem[];
}

const DEFAULT_MENU: SidebarGroup[] = [
  {
    label: 'Power Bi',
    icon: Ellipsis,
    items: [{ label: 'Tableau de bord', href: '/app/home', icon: LayoutDashboard }],
  },
  {
    label: 'Gestion',
    icon: Ellipsis,
    items: [
      { label: 'Produits', href: '/app/products', icon: Package },
      { label: 'Catégories', href: '/app/categories', icon: FolderTree },
      { label: 'Commandes', href: '/app/orders', icon: ShoppingCart },
      { label: 'Clients', href: '/app/clients', icon: Users },
    ],
  },
  {
    label: 'Système',
    icon: Ellipsis,
    items: [
      { label: 'Rapports', href: '/app/reports', icon: FileText },
      { label: 'Paramètres', href: '/app/settings', icon: Settings },
    ],
  },
];

@Component({
  selector: 'app-sidebar',
  imports: [RouterLink, RouterLinkActive, NgOptimizedImage, LucideAngularModule],
  changeDetection: ChangeDetectionStrategy.OnPush,
  templateUrl: './sidebar.component.html',
})
export class Sidebar implements OnDestroy {
  // Menu groups (configurable via input)
  readonly groups = input<SidebarGroup[]>(DEFAULT_MENU);

  // collapsed state: when true only icons are visible (narrow sidebar)
  protected readonly collapsed = signal(false);
  protected readonly hovered = signal(false);
  protected readonly isCollapsed = computed(() => this.collapsed() && !this.hovered());

  // Accordion: only one group open at a time; null => no group forced open
  protected readonly openGroupIndex = signal<number | null>(null);

  // Icons exposed for template
  protected readonly panelClose = PanelLeftClose;
  protected readonly panelOpen = PanelLeftOpen;
  protected readonly moreIcon = Ellipsis;
  protected readonly chevron = ChevronDown;

  // Platform services
  private readonly platformId = inject(PLATFORM_ID);
  private readonly localStorageService = inject(LocalStorageService);
  private readonly router = inject(Router);
  private routerSub: Subscription | null = null;

  constructor() {
    // Restore collapsed state if stored (browser only)
    if (isPlatformBrowser(this.platformId)) {
      const stored = this.localStorageService.getState(SIDEBAR_STORAGE_KEY);
      if (stored !== null) {
        this.collapsed.set(stored === 'true');
      }

      // restore open group index if stored
      const storedGroup = this.localStorageService.getState(`${SIDEBAR_STORAGE_KEY}_group`);
      if (storedGroup !== null) {
        const idx = Number(storedGroup);
        if (!Number.isNaN(idx)) {
          this.openGroupIndex.set(idx);
        } else {
          this.syncOpenGroupWithUrl(this.router.url);
        }
      } else {
        // infer from current URL
        this.syncOpenGroupWithUrl(this.router.url);
      }

      // subscribe to router navigation to update the active group
      this.routerSub = this.router.events.subscribe((ev: Event) => {
        if (ev instanceof NavigationEnd) {
          this.syncOpenGroupWithUrl(ev.urlAfterRedirects || ev.url);
        }
      });
    } else {
      // non-browser environments: try best-effort using router snapshot
      this.syncOpenGroupWithUrl(this.router.url);
    }
  }

  ngOnDestroy(): void {
    if (this.routerSub) {
      this.routerSub.unsubscribe();
      this.routerSub = null;
    }
  }

  toggleCollapsed(): void {
    const next = !this.collapsed();
    this.collapsed.set(next);
    if (isPlatformBrowser(this.platformId)) {
      this.localStorageService.setState(SIDEBAR_STORAGE_KEY, String(next));
    }
  }

  /**
   * Toggle a group's open state (accordion).
   * When a group is opened, others close. Clicking the opened group closes it.
   */
  toggleGroup(index: number): void {
    const current = this.openGroupIndex();
    const next = current === index ? null : index;
    this.openGroupIndex.set(next);
    if (isPlatformBrowser(this.platformId)) {
      this.localStorageService.setState(
        `${SIDEBAR_STORAGE_KEY}_group`,
        next === null ? null : String(next),
      );
    }
  }

  isGroupOpen(index: number): boolean {
    return this.openGroupIndex() === index;
  }

  chevronClass(index: number): string {
    return this.isGroupOpen(index)
      ? 'transform rotate-180 transition-transform duration-200'
      : 'transform rotate-0 transition-transform duration-200';
  }

  /**
   * Choose the best matching group index for the given URL.
   * Uses the longest matching prefix heuristic so sub-routes pick the correct group.
   */
  private syncOpenGroupWithUrl(url: string): void {
    const groups = this.groups();
    let bestIndex: number | null = null;
    let bestLength = -1;

    groups.forEach((g, i) => {
      for (const item of g.items) {
        if (!item.href) continue;
        const href = item.href;
        if (href === url || url.startsWith(href)) {
          if (href.length > bestLength) {
            bestLength = href.length;
            bestIndex = i;
          }
        }
      }
    });

    this.openGroupIndex.set(bestIndex);
  }
}
